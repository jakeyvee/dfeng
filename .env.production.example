# =============================================================================
# Dongfeng Experience Community bot — PRODUCTION environment template (VOL-213)
# =============================================================================
# Copy this file to `.env.production` and fill in real values for the LIVE
# supergroup deployment:
#     cp .env.production.example .env.production
#
# `.env.production` is gitignored (see .gitignore). NEVER commit real tokens,
# group/topic/admin IDs, invite links, or the Google service-account key.
# In production, inject these via your host's secret manager / mounted secret
# file rather than baking them into an image or the repo. All keys are read in
# src/dfeng_bot/config.py. Source-of-truth IDs come from the gitignored
# config/group-setup.yaml (VOL-196) — transcribe them here.
#
# Difference from `.env.example`: this template ENABLES the launch-critical
# feature flags (incl. the moderation features that default OFF in code) — see
# the "PRODUCTION FEATURE FLAGS" section at the bottom and the rationale there.
# -----------------------------------------------------------------------------

# --- Core Telegram (REQUIRED) -----------------------------------------------
# Bot API token from @BotFather. SECRET — provision via secret manager, never
# commit. The bot account must be a group admin with the rights in
# docs/telegram-setup.md §7 (see docs/production-deployment.md).
TELEGRAM_BOT_TOKEN=<PROD_BOT_TOKEN_FROM_BOTFATHER>

# The live supergroup (negative chat id, e.g. -1001234567890). From
# config/group-setup.yaml (VOL-196) -> group_id.
DFENG_GROUP_ID=<PROD_GROUP_ID>

# --- Topic / thread IDs (the six community topics) --------------------------
# message_thread_id of each forum topic. From config/group-setup.yaml (VOL-196).
# IMPORTANT mapping (docs/telegram-setup.md §4 "Topic -> config mapping"):
#   DFENG_TOPIC_ANNOUNCEMENTS = "Announcements & Events"
#   DFENG_TOPIC_BOX           = "BOX Owners Lounge"
#   DFENG_TOPIC_007           = "007 Owners Club"
#   DFENG_TOPIC_VIGO          = "VIGO Owners Circle"
#   DFENG_TOPIC_GENERAL       = built-in General topic (set to 1) = General Community Chat
#   DFENG_TOPIC_SUPPORT       = "Support & Assistance"
# Fill in the real thread_id integers (the env keys match the topics).
DFENG_TOPIC_ANNOUNCEMENTS=<ANNOUNCEMENTS_EVENTS_THREAD_ID>
DFENG_TOPIC_BOX=<BOX_OWNERS_LOUNGE_THREAD_ID>
DFENG_TOPIC_007=<007_OWNERS_CLUB_THREAD_ID>
DFENG_TOPIC_VIGO=<VIGO_OWNERS_CIRCLE_THREAD_ID>
DFENG_TOPIC_GENERAL=1  # built-in General topic, used as General Community Chat
DFENG_TOPIC_SUPPORT=<SUPPORT_ASSISTANCE_THREAD_ID>

# Where to POST the welcome message. 0 = General (where members land) — recommended.
DFENG_WELCOME_TOPIC=0

# --- Entry-source named invite links (VOL-202) ------------------------------
# One Telegram invite link PER tracked entry source (createChatInviteLink; see
# docs/entry-links.md). SENSITIVE join-grant secrets — never commit. Sources
# without a link fall back to the documented default ("salesperson").
DFENG_INVITE_LINK_SHOWROOM=<PROD_SHOWROOM_INVITE_LINK>
DFENG_INVITE_LINK_ROADSHOW=<PROD_ROADSHOW_INVITE_LINK>
DFENG_INVITE_LINK_EVENT=<PROD_EVENT_INVITE_LINK>
DFENG_INVITE_LINK_LINKTREE=<PROD_LINKTREE_INVITE_LINK>

# --- Google Sheets member workbook (VOL-198) --------------------------------
# Provision per docs/google-sheets-setup.md. Enabled below (DFENG_FEATURE_SHEETS=1).
# Workbook id = the URL segment between /d/ and /edit.
DFENG_SHEETS_WORKBOOK_ID=<PROD_GOOGLE_SHEET_ID>
# Worksheet/tab name holding the member rows (canonical 12-col header).
DFENG_SHEETS_TAB_NAME=Members
# Google service-account credentials: a PATH to a JSON key file (mounted secret,
# read-only) OR the raw JSON itself. NEVER commit the key. In Docker this is the
# read-only mount path from docker-compose.yml; on a systemd host a 0600 file.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/dfeng-google-creds.json

# --- Sheets write queue (VOL-206) -------------------------------------------
# Resilient async layer in front of the member-row write seam. Defaults are
# production-safe; keep enabled so a Sheets outage never blocks onboarding.
DFENG_WRITE_QUEUE_ENABLED=1
DFENG_WRITE_QUEUE_MAX_ATTEMPTS=5
DFENG_WRITE_QUEUE_BASE_DELAY=1.0
DFENG_WRITE_QUEUE_MAX_DELAY=30.0
# Quota smoothing (~54 writes/min, under Sheets limits during a roadshow spike).
DFENG_WRITE_QUEUE_MIN_INTERVAL=1.1
DFENG_WRITE_QUEUE_MAX_PENDING=1000

# --- Access control ----------------------------------------------------------
# Comma-separated Telegram user IDs treated as admins/moderators (all L1/L2/L3).
# From config/group-setup.yaml (VOL-196) admins: register.
DFENG_ADMIN_IDS=<ADMIN_ID_1>,<ADMIN_ID_2>,<ADMIN_ID_3>

# --- Trust thresholds --------------------------------------------------------
DFENG_TRUST_THRESHOLD=3

# --- New-user link restrictions (VOL-209) -----------------------------------
# ENABLED below. A member is TRUSTED (may post links) when ANY holds: join age
# >= MIN_AGE, OR clean messages >= MIN_MESSAGES, OR qualified, OR a mod /trust'd.
DFENG_LINK_TRUST_MIN_AGE_SECONDS=86400
DFENG_LINK_TRUST_MIN_MESSAGES=3
DFENG_LINK_EXEMPT_ADMINS=1
# 0 = delete + friendly notice (default); 1 = silent removal.
DFENG_LINK_SILENT=0

# --- Flood control / rate limits (VOL-210) ----------------------------------
# ENABLED below. Per-user across the WHOLE supergroup. Defaults (> 8 msgs / 10s)
# are lenient so normal active chat never trips.
DFENG_RATE_LIMIT_MESSAGES=8
DFENG_RATE_LIMIT_WINDOW_SECONDS=10
# warn | mute | delete | mute_delete. "mute" = reversible auto-expiring mute.
DFENG_RATE_LIMIT_ACTION=mute
DFENG_RATE_LIMIT_MUTE_SECONDS=600
DFENG_RATE_LIMIT_EXEMPT_ADMINS=1

# --- Anti-spam settings (VOL-208) -------------------------------------------
# Feature ENABLED below (DFENG_FEATURE_ANTISPAM=1). These tune its behaviour.
DFENG_SPAM_BLOCK_LINKS=1
# Community/official domains ALWAYS allowed.
DFENG_SPAM_ALLOWED_DOMAINS=dongfeng.com
DFENG_SPAM_EXEMPT_ADMINS=1
DFENG_SPAM_REPEAT_COUNT=3
DFENG_SPAM_REPEAT_WINDOW_SECONDS=60
# Escalation off by default at launch (0 = delete + log only; no auto-restrict).
# Raise during a raid per docs/moderation-runbook.md §6.
DFENG_SPAM_RESTRICT_AFTER=0
DFENG_SPAM_RESTRICT_SECONDS=3600
# Rule lists: leave BLANK to use built-in defaults, or manage long lists in the
# gitignored config/spam-rules.yaml (overrides these env vars when present).
DFENG_SPAM_CRYPTO_KEYWORDS=
DFENG_SPAM_AD_KEYWORDS=
DFENG_SPAM_SHORTENER_DOMAINS=
DFENG_SPAM_BLOCKED_DOMAINS=
DFENG_SPAM_BLOCKED_TLDS=
# DFENG_SPAM_RULES_FILE=config/spam-rules.yaml

# --- Runtime mode ------------------------------------------------------------
# "polling" (default, recommended for v1) or "webhook". See
# docs/production-deployment.md "Polling vs webhook".
DFENG_RUN_MODE=polling
# Webhook settings (only used when DFENG_RUN_MODE=webhook):
DFENG_WEBHOOK_URL=https://bot.example.com/telegram
DFENG_WEBHOOK_LISTEN=0.0.0.0
DFENG_WEBHOOK_PORT=8443
# Generate a random value (e.g. `openssl rand -hex 16`). SECRET.
DFENG_WEBHOOK_SECRET_TOKEN=<RANDOM_WEBHOOK_SECRET>

# =============================================================================
# PRODUCTION FEATURE FLAGS (VOL-213) — launch-critical set
# =============================================================================
# 1 = enabled, 0 = disabled. The PRD requires anti-spam ACTIVE on day one, so
# production turns ON the moderation features that ship dark (default OFF in
# code as a safety measure). Rationale below.
#
# Launch-on (non-destructive subsystems):
DFENG_FEATURE_WELCOME=1            # welcome on join
DFENG_FEATURE_QUALIFICATION=1     # qualification -> tag flow
DFENG_FEATURE_OPTIONAL_CAPTURE=1  # PDPA-gated optional phone/plate capture
DFENG_FEATURE_SUPPORT_REDIRECT=1  # support-keyword nudge to Support topic
DFENG_FEATURE_SHEETS=1            # real Google Sheets writes (needs workbook+creds above)
#
# Launch-on (moderation — DEFAULT OFF IN CODE, prod MUST turn ON):
# These are intentionally opt-in because they delete/mute/restrict members; a
# misconfiguration could remove legitimate content. The PRD requires anti-spam
# live at launch, and the moderation runbook (VOL-211) treats these three as the
# kill-switch flags. Production enables them; to roll one back during an incident
# flip it to 0 and restart (no redeploy) — see docs/production-deployment.md
# "Rollback / disable a feature" and docs/moderation-runbook.md §6.
DFENG_FEATURE_ANTISPAM=1          # automated spam-link/keyword/repeat removal
DFENG_FEATURE_FLOOD_CONTROL=1     # per-user rate-limit (lenient defaults)
DFENG_FEATURE_LINK_RESTRICTIONS=1 # block links from new/low-trust members

# --- Logging -----------------------------------------------------------------
# Level: DEBUG, INFO, WARNING, ERROR. INFO recommended for prod.
DFENG_LOG_LEVEL=INFO
# "kv" (key=value, default) or "json" (set json when shipping to an aggregator).
DFENG_LOG_FORMAT=kv

# --- Metrics (VOL-212) -------------------------------------------------------
# PII-safe per-message activity event for launch metrics. Keep ON.
DFENG_METRICS_ACTIVITY=1
