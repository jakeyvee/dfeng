# --- Secrets & credentials (NEVER commit) ---
.env
.env.*
!.env.example
# Production env (VOL-213): real secrets/IDs live here — NEVER commit. The
# `.env.*` rule above already ignores it; this line documents the intent and the
# negation below keeps ONLY the placeholder template (.env.production.example) tracked.
.env.production
!.env.production.example
# Filled-in supergroup setup notes (real group/admin ids, invite link).
# Only the *.example template is committed — see config/group-setup.example.yaml.
config/group-setup.yaml
config/group-setup.yml
# Filled-in pinned-message-ids notes (real group/topic ids) — VOL-201.
# Only the *.example template is committed — see config/pinned-message-ids.example.yaml.
config/pinned-message-ids.yaml
config/pinned-message-ids.yml
# Tuned anti-spam rule lists — VOL-208. Only the *.example template is committed;
# the live config/spam-rules.yaml (if used) stays local.
config/spam-rules.yaml
config/spam-rules.yml
*.json
!**/package.json
!**/tsconfig.json
service-account*.json
*credentials*.json
*-key.json

# --- Generated QR codes (VOL-202) — encode real invite links, never commit. ---
# scripts/generate_qr.py writes PNGs here; keep the dir via .gitkeep.
assets/qr/*.png

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Tooling / caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
*.swp
