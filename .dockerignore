# Keep secrets, local env, creds, and cruft OUT of the build context/image.
.env
.env.*
!.env.production.example
*.json
!**/package.json
!**/tsconfig.json
service-account*.json
*credentials*.json
*-key.json
config/group-setup.yaml
config/group-setup.yml
config/pinned-message-ids.yaml
config/spam-rules.yaml

.git
.gitignore
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.DS_Store
.vscode/
.idea/
assets/qr/*.png
