# =============================================================================
# Dongfeng Experience Community bot — example environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values for local development:
#     cp .env.example .env
#
# `.env` is gitignored. NEVER commit real tokens, IDs, or credentials.
# In production, inject these via your platform's secret manager rather than a
# committed file. All keys are read in src/dfeng_bot/config.py.
# -----------------------------------------------------------------------------

# --- Core Telegram (REQUIRED) -----------------------------------------------
# Bot API token from @BotFather. Treat as a secret.
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_REAL_TOKEN

# The supergroup (negative chat id, e.g. -1001234567890) the bot serves.
DFENG_GROUP_ID=-1001234567890

# --- Topic / thread IDs (5 created topics + built-in General) ----------------
# message_thread_id of each forum topic. Integers. Env keys match the topics.
# DFENG_TOPIC_GENERAL = the built-in General topic (id 1), used as the
# "General Community Chat" — only five topics are created. See docs/telegram-setup.md.
DFENG_TOPIC_ANNOUNCEMENTS=7     # Announcements & Events
DFENG_TOPIC_BOX=2              # BOX Owners Lounge
DFENG_TOPIC_007=4             # 007 Owners Club
DFENG_TOPIC_VIGO=6            # VIGO Owners Circle
DFENG_TOPIC_GENERAL=1          # General Community Chat (built-in General)
DFENG_TOPIC_SUPPORT=5          # Support & Assistance

# Where to POST the welcome message. 0 = post in General, where new members land
# (recommended). Set to a thread id to force the welcome into a specific topic.
DFENG_WELCOME_TOPIC=0

# --- Entry-source named invite links (VOL-202) ------------------------------
# One Telegram invite link PER tracked entry source. Create each via the Bot API
# (createChatInviteLink, optionally creates_join_request=true for invite-only) —
# see docs/entry-links.md for the exact steps and the link -> source mapping.
# The bot reads the invite_link echoed on the join update and maps it back to a
# canonical source id (services/entry_source.py, must match schema.ENTRY_SOURCES).
# Treat each link as SENSITIVE (anyone with it can request to join) — never
# commit real links; keep them only in your gitignored .env / secret manager.
# Sources WITHOUT a link here ("salesperson", "website placeholder") and any
# unknown link fall back to the documented default: "salesperson".
DFENG_INVITE_LINK_SHOWROOM=https://t.me/+REPLACE_WITH_SHOWROOM_INVITE
DFENG_INVITE_LINK_ROADSHOW=https://t.me/+REPLACE_WITH_ROADSHOW_INVITE
DFENG_INVITE_LINK_EVENT=https://t.me/+REPLACE_WITH_EVENT_INVITE
DFENG_INVITE_LINK_LINKTREE=https://t.me/+REPLACE_WITH_LINKTREE_INVITE

# Bot @username (no @). REQUIRED when DFENG_FEATURE_DM_PII_CAPTURE=1 — used to
# build the "Share privately" deep-link button (t.me/<username>?start=profile).
DFENG_BOT_USERNAME=

# --- Google Sheets member workbook (VOL-198) --------------------------------
# Provision per docs/google-sheets-setup.md. Enable with DFENG_FEATURE_SHEETS=1
# (see Feature flags below); when off/unconfigured the bot uses a no-op client.
# Workbook id = the URL segment between /d/ and /edit.
DFENG_SHEETS_WORKBOOK_ID=REPLACE_WITH_GOOGLE_SHEET_ID
# Worksheet/tab name holding the member rows (header per config/sheets-schema.md).
DFENG_SHEETS_TAB_NAME=Members
# Google service-account credentials: a PATH to a JSON key file (gitignored), or
# the raw JSON itself. NEVER commit the key. See docs/google-sheets-setup.md.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Sheets write queue (VOL-206) -------------------------------------------
# Resilient async layer in front of the member-row write seam so a Sheets outage
# NEVER blocks onboarding. enqueue() returns immediately; a background worker
# drains with exponential-backoff retries and, on exhaustion, dead-letters the
# write (admin-visible via /sheets_status and /reconcile) + best-effort sets the
# admin "Status" column to NEEDS_RECONCILIATION.
# Durability tradeoff: the pending queue + dead-letter list are IN-MEMORY ONLY —
# lost on restart (accepted v1; records are idempotent + re-derivable and every
# affected Telegram ID is logged). See src/dfeng_bot/services/write_queue.py.
# Enable the queue (1=on default; 0 = fall back to VOL-205's direct write path).
DFENG_WRITE_QUEUE_ENABLED=1
# Max retry attempts per write before dead-lettering.
DFENG_WRITE_QUEUE_MAX_ATTEMPTS=5
# Exponential backoff: delay = base * 2**(attempt-1), capped at max (seconds).
DFENG_WRITE_QUEUE_BASE_DELAY=1.0
DFENG_WRITE_QUEUE_MAX_DELAY=30.0
# Quota smoothing: minimum seconds between writes leaving the worker. ~1.1s keeps
# sustained throughput (~54 writes/min) under the Sheets limits (300 write/min/
# project, 60 req/min/user) during a roadshow spike (50 joins in minutes).
DFENG_WRITE_QUEUE_MIN_INTERVAL=1.1
# Bound on the in-memory pending queue; overflow is dead-lettered (not silently lost).
DFENG_WRITE_QUEUE_MAX_PENDING=1000

# --- Access control ----------------------------------------------------------
# Comma-separated Telegram user IDs treated as admins/moderators.
DFENG_ADMIN_IDS=11111111,22222222

# --- Trust thresholds --------------------------------------------------------
# Minimum "trust score" a member needs before relaxed restrictions apply.
DFENG_TRUST_THRESHOLD=3

# --- New-user link restrictions (VOL-209) -----------------------------------
# Block links from new / low-trust members until they cross the TRUST THRESHOLD.
# Gate with DFENG_FEATURE_LINK_RESTRICTIONS=1 (see Feature flags below).
# A member is TRUSTED (may post links) when ANY of these holds (OR, not AND):
#   * join age >= DFENG_LINK_TRUST_MIN_AGE_SECONDS (default 86400 = 24h); OR
#   * clean (non-link) message count >= DFENG_LINK_TRUST_MIN_MESSAGES (default 3); OR
#   * they completed qualification (VOL-204); OR
#   * a moderator ran /trust on them (or they are an admin — exempt up front).
DFENG_LINK_TRUST_MIN_AGE_SECONDS=86400
DFENG_LINK_TRUST_MIN_MESSAGES=3
# Exempt admins/moderators (DFENG_ADMIN_IDS) from link restrictions (1=on, 0=apply to all).
DFENG_LINK_EXEMPT_ADMINS=1
# Removal style on a blocked link: 0 = delete + reply a friendly notice (default),
# 1 = silent removal (delete, no reply).
DFENG_LINK_SILENT=0

# --- Flood control / rate limits (VOL-210) ----------------------------------
# Per-user flood control across the WHOLE supergroup (ALL forum topics combined,
# NOT per-topic). Gate with DFENG_FEATURE_FLOOD_CONTROL=1 (see Feature flags).
# Trip when a user sends MORE THAN max-messages within the rolling window.
# Defaults (> 8 msgs / 10s) are lenient so normal active chat never trips.
DFENG_RATE_LIMIT_MESSAGES=8
DFENG_RATE_LIMIT_WINDOW_SECONDS=10
# Action on trip: warn | mute | delete | mute_delete.
#   warn        = log + warn the user in-thread (no removal/mute).
#   mute        = log + temporary, auto-expiring REVERSIBLE mute (default).
#   delete      = log + remove the offending message only.
#   mute_delete = delete the message AND apply the temporary mute.
DFENG_RATE_LIMIT_ACTION=mute
# Mute duration in seconds (time-bounded via restrict_chat_member until_date,
# so mutes auto-expire — reversible without manual unmute).
DFENG_RATE_LIMIT_MUTE_SECONDS=600
# Exempt admins/moderators (DFENG_ADMIN_IDS) from flood control (1=on, 0=apply to all).
DFENG_RATE_LIMIT_EXEMPT_ADMINS=1

# --- Anti-spam settings (VOL-208) -------------------------------------------
# Enable removal of suspicious links (shorteners, t.me invites, scam domains/TLDs).
# (New-user / low-trust link restriction is VOL-209; this is the always-spammy set.)
DFENG_SPAM_BLOCK_LINKS=1
# Comma-separated link domains ALWAYS allowed (community/official links).
DFENG_SPAM_ALLOWED_DOMAINS=dongfeng.com
# Exempt admins/moderators (DFENG_ADMIN_IDS) from spam rules (1=on default, 0=apply to all).
DFENG_SPAM_EXEMPT_ADMINS=1
# Repetition: N identical/near-identical messages by one user within the window.
DFENG_SPAM_REPEAT_COUNT=3
DFENG_SPAM_REPEAT_WINDOW_SECONDS=60
# Optional escalation: temporarily mute a user after this many removed messages
# (0=delete+log only; no restrict). Restrict duration in seconds.
DFENG_SPAM_RESTRICT_AFTER=0
DFENG_SPAM_RESTRICT_SECONDS=3600
# Rule lists (crypto/ad/shortener/blocked-domain/blocked-TLD keywords) are
# managed in the committed, editable file >>> config/spam-rules.yaml <<< which is
# pre-loaded with the defaults — edit it to add/remove entries, then restart.
# These env vars are an optional override and are normally left BLANK (the YAML
# file wins when present). Comma-separated if you do set one.
DFENG_SPAM_CRYPTO_KEYWORDS=
DFENG_SPAM_AD_KEYWORDS=
DFENG_SPAM_SHORTENER_DOMAINS=
DFENG_SPAM_BLOCKED_DOMAINS=
DFENG_SPAM_BLOCKED_TLDS=
# Optional path to a YAML rules file (default: config/spam-rules.yaml if present).
# DFENG_SPAM_RULES_FILE=config/spam-rules.yaml

# --- Runtime mode ------------------------------------------------------------
# "polling" (default for v1) or "webhook".
DFENG_RUN_MODE=polling
# Webhook settings (only used when DFENG_RUN_MODE=webhook):
DFENG_WEBHOOK_URL=https://bot.example.com/telegram
DFENG_WEBHOOK_LISTEN=0.0.0.0
DFENG_WEBHOOK_PORT=8443
# Optional secret token Telegram echoes back to verify webhook calls.
DFENG_WEBHOOK_SECRET_TOKEN=REPLACE_WITH_RANDOM_STRING

# --- Feature flags -----------------------------------------------------------
# Toggle subsystems future tickets implement. 1=enabled, 0=disabled.
DFENG_FEATURE_WELCOME=1
DFENG_FEATURE_QUALIFICATION=1
# PDPA-gated optional profile capture + member persistence (VOL-205). Default ON:
# after qualification assigns a tag, the bot shows the locked PDPA notice
# (policy.PDPA_CONSENT_NOTICE) and offers OPTIONAL, individually-skippable phone
# and plate capture, then upserts the member row (idempotent on Telegram ID) via
# the Sheets service. When OFF, the PDPA/optional steps are skipped but required
# fields are still persisted. Actual Sheets writes also require DFENG_FEATURE_SHEETS=1
# (+ workbook/credentials); otherwise persistence is a logged no-op.
DFENG_FEATURE_OPTIONAL_CAPTURE=1
DFENG_FEATURE_SHEETS=0
DFENG_FEATURE_ANTISPAM=0
DFENG_FEATURE_FLOOD_CONTROL=0
# New-user link restrictions (VOL-209). Default OFF (restrictive feature; ships
# dark, enabled per environment / by VOL-213). See "New-user link restrictions".
DFENG_FEATURE_LINK_RESTRICTIONS=0
# Support-keyword redirection (VOL-207): nudge support-flavoured messages posted
# outside the Support topic toward Support & Assistance. Default ON.
DFENG_FEATURE_SUPPORT_REDIRECT=1
# Collect optional phone/plate PRIVATELY in the bot DM instead of the public
# topic: after qualification the bot posts a benefit-led "Share privately" button
# that opens the bot chat; PII is captured there. Requires DFENG_BOT_USERNAME.
# Default OFF (in-group capture, with the typed message auto-deleted). 1 to enable.
DFENG_FEATURE_DM_PII_CAPTURE=0

# --- Logging -----------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR.
DFENG_LOG_LEVEL=INFO
# Log format: "kv" (key=value, default) or "json".
DFENG_LOG_FORMAT=kv

# --- Metrics (VOL-212) -------------------------------------------------------
# Emit the low-noise per-message "message_activity" event used for launch
# metrics (weekly-active, owner/prospect messages). PII-safe: logs
# telegram_id/thread_id/tag/is_question only — never the message body.
# Default ON; set to 0 to silence (weekly-active metric then uncomputable).
# See docs/metrics-and-reporting.md.
DFENG_METRICS_ACTIVITY=1
